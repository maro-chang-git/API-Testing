{
  "meta": {
    "api_name": "Testek - Product Management",
    "base_url": "https://testek.vn/lab/api/v0/prod-man",
    "version": "2.2.8",
    "auth_note": "All endpoints require Bearer token via Authorization header"
  },
  "testcases": [
    {
      "id": "TC-PRD-001",
      "group": "Product",
      "method": "POST",
      "endpoint": "/product",
      "summary": "Create a new product",
      "auth_type": "bearer_token",
      "auth_status": "valid",
      "category": "happy_path",
      "purpose": "Successfully create a product with all required fields",
      "expected_status": 201,
      "notes": "Response wraps data in ServiceResponse { code, data, message }"
    },
    {
      "id": "TC-PRD-002",
      "group": "Product",
      "method": "POST",
      "endpoint": "/product",
      "summary": "Create a new product",
      "auth_type": "bearer_token",
      "auth_status": "missing",
      "category": "auth",
      "purpose": "Reject create request when Authorization header is absent",
      "expected_status": 401,
      "notes": "No Authorization header sent"
    },
    {
      "id": "TC-PRD-003",
      "group": "Product",
      "method": "POST",
      "endpoint": "/product",
      "summary": "Create a new product",
      "auth_type": "bearer_token",
      "auth_status": "invalid",
      "category": "auth",
      "purpose": "Reject create request when token is malformed or expired",
      "expected_status": 401,
      "notes": "Send Authorization: Bearer invalid_token_xyz"
    },
    {
      "id": "TC-PRD-004",
      "group": "Product",
      "method": "POST",
      "endpoint": "/product",
      "summary": "Create a new product",
      "auth_type": "bearer_token",
      "auth_status": "valid",
      "category": "validation",
      "purpose": "Reject create request when required fields are missing in request body",
      "expected_status": 400,
      "notes": "Send empty body {}"
    },
    {
      "id": "TC-PRD-005",
      "group": "Product",
      "method": "POST",
      "endpoint": "/product",
      "summary": "Create a new product",
      "auth_type": "bearer_token",
      "auth_status": "valid",
      "category": "validation",
      "purpose": "Reject create request when field values are invalid types or out of range",
      "expected_status": 400,
      "notes": "e.g. price = -1, name = null"
    },
    {
      "id": "TC-PRD-006",
      "group": "Product",
      "method": "GET",
      "endpoint": "/product/search",
      "summary": "Search products",
      "auth_type": "bearer_token",
      "auth_status": "valid",
      "category": "happy_path",
      "purpose": "Return paginated product list with default params",
      "expected_status": 200,
      "notes": "No query params — should use API defaults for page/size"
    },
    {
      "id": "TC-PRD-007",
      "group": "Product",
      "method": "GET",
      "endpoint": "/product/search",
      "summary": "Search products",
      "auth_type": "bearer_token",
      "auth_status": "valid",
      "category": "happy_path",
      "purpose": "Return filtered product list matching a keyword",
      "expected_status": 200,
      "notes": "Query param: keyword=<existing product name>"
    },
    {
      "id": "TC-PRD-008",
      "group": "Product",
      "method": "GET",
      "endpoint": "/product/search",
      "summary": "Search products",
      "auth_type": "bearer_token",
      "auth_status": "valid",
      "category": "happy_path",
      "purpose": "Return empty list when keyword matches no products",
      "expected_status": 200,
      "notes": "Query param: keyword=zzznomatch999 — data array should be empty"
    },
    {
      "id": "TC-PRD-009",
      "group": "Product",
      "method": "GET",
      "endpoint": "/product/search",
      "summary": "Search products",
      "auth_type": "bearer_token",
      "auth_status": "missing",
      "category": "auth",
      "purpose": "Reject search request when Authorization header is absent",
      "expected_status": 401,
      "notes": ""
    },
    {
      "id": "TC-PRD-010",
      "group": "Product",
      "method": "GET",
      "endpoint": "/product/search",
      "summary": "Search products",
      "auth_type": "bearer_token",
      "auth_status": "invalid",
      "category": "auth",
      "purpose": "Reject search request when token is malformed or expired",
      "expected_status": 401,
      "notes": ""
    },
    {
      "id": "TC-PRD-011",
      "group": "Product",
      "method": "GET",
      "endpoint": "/product/{id}/detail",
      "summary": "Get product detail",
      "auth_type": "bearer_token",
      "auth_status": "valid",
      "category": "happy_path",
      "purpose": "Return full detail of an existing product by ID",
      "expected_status": 200,
      "notes": "Use a known valid product ID"
    },
    {
      "id": "TC-PRD-012",
      "group": "Product",
      "method": "GET",
      "endpoint": "/product/{id}/detail",
      "summary": "Get product detail",
      "auth_type": "bearer_token",
      "auth_status": "valid",
      "category": "error_handling",
      "purpose": "Return 404 when product ID does not exist",
      "expected_status": 404,
      "notes": "Use ID: 999999999"
    },
    {
      "id": "TC-PRD-013",
      "group": "Product",
      "method": "GET",
      "endpoint": "/product/{id}/detail",
      "summary": "Get product detail",
      "auth_type": "bearer_token",
      "auth_status": "valid",
      "category": "validation",
      "purpose": "Return 400 when product ID is not a valid format",
      "expected_status": 400,
      "notes": "Use ID: abc (non-numeric)"
    },
    {
      "id": "TC-PRD-014",
      "group": "Product",
      "method": "GET",
      "endpoint": "/product/{id}/detail",
      "summary": "Get product detail",
      "auth_type": "bearer_token",
      "auth_status": "missing",
      "category": "auth",
      "purpose": "Reject detail request when Authorization header is absent",
      "expected_status": 401,
      "notes": ""
    },
    {
      "id": "TC-PRD-015",
      "group": "Product",
      "method": "PUT",
      "endpoint": "/product/{id}",
      "summary": "Update a product",
      "auth_type": "bearer_token",
      "auth_status": "valid",
      "category": "happy_path",
      "purpose": "Successfully update an existing product's fields",
      "expected_status": 200,
      "notes": "Update name or price on a known existing product"
    },
    {
      "id": "TC-PRD-016",
      "group": "Product",
      "method": "PUT",
      "endpoint": "/product/{id}",
      "summary": "Update a product",
      "auth_type": "bearer_token",
      "auth_status": "valid",
      "category": "error_handling",
      "purpose": "Return 404 when updating a product that does not exist",
      "expected_status": 404,
      "notes": "Use ID: 999999999"
    },
    {
      "id": "TC-PRD-017",
      "group": "Product",
      "method": "PUT",
      "endpoint": "/product/{id}",
      "summary": "Update a product",
      "auth_type": "bearer_token",
      "auth_status": "valid",
      "category": "validation",
      "purpose": "Reject update when request body contains invalid field values",
      "expected_status": 400,
      "notes": "e.g. price = -999"
    },
    {
      "id": "TC-PRD-018",
      "group": "Product",
      "method": "PUT",
      "endpoint": "/product/{id}",
      "summary": "Update a product",
      "auth_type": "bearer_token",
      "auth_status": "missing",
      "category": "auth",
      "purpose": "Reject update request when Authorization header is absent",
      "expected_status": 401,
      "notes": ""
    },
    {
      "id": "TC-PRD-019",
      "group": "Product",
      "method": "PUT",
      "endpoint": "/product/{id}",
      "summary": "Update a product",
      "auth_type": "bearer_token",
      "auth_status": "invalid",
      "category": "auth",
      "purpose": "Reject update request when token is malformed or expired",
      "expected_status": 401,
      "notes": ""
    },
    {
      "id": "TC-PRD-020",
      "group": "Product",
      "method": "DELETE",
      "endpoint": "/product/{id}",
      "summary": "Delete a product",
      "auth_type": "bearer_token",
      "auth_status": "valid",
      "category": "happy_path",
      "purpose": "Successfully delete an existing product by ID",
      "expected_status": 200,
      "notes": "Verify product is no longer retrievable via GET /product/{id}/detail after deletion"
    },
    {
      "id": "TC-PRD-021",
      "group": "Product",
      "method": "DELETE",
      "endpoint": "/product/{id}",
      "summary": "Delete a product",
      "auth_type": "bearer_token",
      "auth_status": "valid",
      "category": "error_handling",
      "purpose": "Return 404 when deleting a product that does not exist",
      "expected_status": 404,
      "notes": "Use ID: 999999999"
    },
    {
      "id": "TC-PRD-022",
      "group": "Product",
      "method": "DELETE",
      "endpoint": "/product/{id}",
      "summary": "Delete a product",
      "auth_type": "bearer_token",
      "auth_status": "missing",
      "category": "auth",
      "purpose": "Reject delete request when Authorization header is absent",
      "expected_status": 401,
      "notes": ""
    },
    {
      "id": "TC-PRD-023",
      "group": "Product",
      "method": "DELETE",
      "endpoint": "/product/{id}",
      "summary": "Delete a product",
      "auth_type": "bearer_token",
      "auth_status": "invalid",
      "category": "auth",
      "purpose": "Reject delete request when token is malformed or expired",
      "expected_status": 401,
      "notes": ""
    },
    {
      "id": "TC-PRD-024",
      "group": "Product",
      "method": "DELETE",
      "endpoint": "/product/{id}",
      "summary": "Delete a product",
      "auth_type": "bearer_token",
      "auth_status": "valid",
      "category": "error_handling",
      "purpose": "Verify product cannot be fetched after successful deletion",
      "expected_status": 404,
      "notes": "Follow-up GET /product/{id}/detail using the just-deleted ID"
    }
  ]
}
